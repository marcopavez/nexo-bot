# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Meta / WhatsApp Cloud API — https://developers.facebook.com/apps
META_ACCESS_TOKEN=         # System user access token (never expires)
META_APP_SECRET=           # App Secret (Settings > Basic)
WEBHOOK_VERIFY_TOKEN=      # Any random string you choose (e.g. nexo-bot-2025)

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY= # Service role key (not the anon key)

# Upstash Redis — https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Admin panel — any strong random string; used to derive the session cookie
ADMIN_SECRET=
